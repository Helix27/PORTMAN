# PORTMAN Environment Configuration
# Copy this to .env and fill in actual values

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/portman
FLASK_SECRET_KEY=portman-secret-key-2024

# ===== SAP PI REST API (DynaportInvoice) =====

# DEV Environment
SAP_DEV_BASE_URL=https://sappidev.example.com:50001/RESTAdapter/DynaportInvoice
SAP_DEV_TOKEN_URL=https://sappidev.example.com:50001/oauth2/api/v1/generateToken
SAP_DEV_CLIENT_ID=
SAP_DEV_CLIENT_SECRET=

# QAS Environment
SAP_QAS_BASE_URL=https://sappiqas.example.com:52401/RESTAdapter/DynaportInvoice
SAP_QAS_TOKEN_URL=https://sappiqas.example.com:52401/oauth2/api/v1/generateToken
SAP_QAS_CLIENT_ID=
SAP_QAS_CLIENT_SECRET=

# PROD Environment
SAP_PROD_BASE_URL=https://sappiprod.example.com:54001/RESTAdapter/DynaportInvoice
SAP_PROD_TOKEN_URL=https://sappiprod.example.com:54001/oauth2/api/v1/generateToken
SAP_PROD_CLIENT_ID=
SAP_PROD_CLIENT_SECRET=

# SAP Company Defaults
SAP_COMPANY_CODE=5171
SAP_PAYMENT_TERM=51

# ===== GST e-Invoice (IRP via GSP) =====

# Sandbox
GST_SANDBOX_API_URL=https://einv-apisandbox.nic.in
GST_SANDBOX_ASP_ID=
GST_SANDBOX_ASP_SECRET=

# Production
GST_PROD_API_URL=https://einv-api.nic.in
GST_PROD_ASP_ID=
GST_PROD_ASP_SECRET=

# GST Common
GST_GSTIN=
GST_PUBLIC_KEY_PATH=keys/irp_public_key.pem
